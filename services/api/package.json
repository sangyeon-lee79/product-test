{
	"name": "@petfolio/api",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "tsc --noEmit",
		"check:i18n:audit": "npx wrangler d1 execute pet-life-db --remote --config wrangler.jsonc --file src/db/queries/audit_i18n_quality.sql",
		"check:i18n:master": "bash scripts/check_master_i18n_before_deploy.sh",
		"deploy:guarded": "npm run check:i18n:master && wrangler deploy",
		"deploy": "wrangler deploy",
		"db:up": "docker compose -f ../../docker-compose.yml up -d postgres",
		"db:reset": "docker compose -f ../../docker-compose.yml down -v && docker compose -f ../../docker-compose.yml up -d postgres",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.0.2",
		"@petfolio/shared": "*",
		"pg": "^8.20.0"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"@types/node": "^25.3.3",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.70.0"
	}
}
