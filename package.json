{
  "name": "petfolio-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=services/api",
    "dev:web": "npm run dev --workspace=apps/guardian-web",
    "dev:admin": "npm run dev --workspace=apps/admin-web",
    "build:all": "npm run build --workspaces --if-present",
    "test:all": "npm run test --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
